<Window x:Class="FreeMon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FreeMon — мониторинг железа"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBgBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ====== Шапка ====== -->
        <Grid Grid.Row="0" Margin="2,0,2,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Border Width="34" Height="34" CornerRadius="9" Background="#23262E" VerticalAlignment="Center">
                    <Path Data="M2,10 L5,10 L7,4 L10,16 L12,10 L16,10"
                          Stroke="#EF9F27" StrokeThickness="1.7" Stretch="None"
                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="FreeMon" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="бесплатный мониторинг железа" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </StackPanel>

            <Button x:Name="ToggleOverlayBtn" Content="Показать оверлей"
                    Style="{StaticResource AccentButton}" HorizontalAlignment="Right"
                    VerticalAlignment="Center" MinWidth="170" Click="ToggleOverlayBtn_Click"/>
        </Grid>

        <!-- ====== Тело ====== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="330"/>
            </Grid.ColumnDefinitions>

            <!-- Левая карточка: датчики -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="16,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Датчики" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBox x:Name="SearchBox" Width="260" Height="32" HorizontalAlignment="Right"
                                 VerticalContentAlignment="Center" TextChanged="SearchBox_TextChanged"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="SensorList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,2,10,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Style="{StaticResource ModernCheck}"
                                                  Content="{Binding Name}"
                                                  IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Pretty}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,12,0,5">
                                                <Border Width="4" Height="15" CornerRadius="2"
                                                        Background="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Name}" FontSize="13"
                                                           FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Правая карточка: оформление -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="18,16">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="Оформление оверлея" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,14"/>

                        <!-- FPS -->
                        <CheckBox x:Name="FpsCheck" Style="{StaticResource ModernCheck}"
                                  Content="Считать FPS активного окна"
                                  Checked="FpsCheck_Changed" Unchecked="FpsCheck_Changed"/>
                        <TextBlock x:Name="FpsStatus" Text="FPS выключен" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="27,3,0,16" TextWrapping="Wrap"/>

                        <!-- Шрифт -->
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Размер шрифта" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                            <TextBlock x:Name="FontVal" Text="14" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                        </DockPanel>
                        <Slider x:Name="FontSizeSlider" Style="{StaticResource ModernSlider}"
                                Minimum="11" Maximum="24" Value="14" Margin="0,0,0,18"
                                ValueChanged="OverlayStyleChanged"/>

                        <!-- Цвет -->
                        <TextBlock Text="Цвет значений" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,7"/>
                        <WrapPanel x:Name="ColorSwatches" Margin="0,0,0,18"/>

                        <!-- Прозрачность -->
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Прозрачность фона" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                            <TextBlock x:Name="OpacityVal" Text="92%" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                        </DockPanel>
                        <Slider x:Name="BgOpacitySlider" Style="{StaticResource ModernSlider}"
                                Minimum="0.2" Maximum="1" Value="0.92" Margin="0,0,0,18"
                                ValueChanged="OverlayStyleChanged"/>

                        <!-- Интервал -->
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Интервал обновления" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                            <TextBlock x:Name="IntervalVal" Text="1000 мс" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                        </DockPanel>
                        <Slider x:Name="IntervalSlider" Style="{StaticResource ModernSlider}"
                                Minimum="200" Maximum="2000" Value="1000" Margin="0,0,0,18"
                                ValueChanged="IntervalSlider_Changed"/>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,16"/>

                        <CheckBox x:Name="LockCheck" Style="{StaticResource ModernCheck}"
                                  Content="Зафиксировать (клик сквозь)" Margin="0,0,0,16"
                                  Checked="LockCheck_Changed" Unchecked="LockCheck_Changed"/>

                        <Button Content="Снять все галочки" Style="{StaticResource ModernButton}"
                                HorizontalAlignment="Stretch" Click="ClearSelection_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
